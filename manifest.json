{
  "manifest_version": 3,
  "name": "MecCollab — Email Task Assignor",
  "short_name": "MecCollab",
  "version": "1.0.0",
  "description": "Automatically reads Gmail emails and assigns tasks in MecCollab via Firestore.",
  "permissions": [
    "identity",
    "storage",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "https://www.googleapis.com/*",
    "https://firestore.googleapis.com/*",
    "https://mail.google.com/*"
  ],
  "oauth2": {
    "client_id": "YOUR_OAUTH_CLIENT_ID.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/gmail.readonly",
      "https://www.googleapis.com/auth/datastore",
      "profile",
      "email"
    ]
  },
  "background": {
    "service_worker": "background/service_worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "MecCollab Task Assignor",
    "default_icon": {
      "128": "icons/icon_128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content/gmail_reader.js"],
      "run_at": "document_idle"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'; base-uri 'none';"
  },
  "icons": {
    "128": "icons/icon_128.png"
  }
}
